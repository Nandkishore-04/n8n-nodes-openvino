# Copy to .env and fill in. The stack refuses to start if a required var is unset.
# (Linux / Podman container deploy. Windows users run the gateway natively — see the README.)

# Render group for Intel GPU/NPU device passthrough into containers
# Run: stat -c "%g" /dev/dri/render*
# Typical value on Ubuntu 24.04: 992
RENDER_GROUP_ID=992

# Postgres credentials (required)
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-to-a-strong-password

# n8n credential-encryption key (required) — generate with: openssl rand -hex 16
# If this changes, previously stored credentials become unreadable. Keep it stable.
N8N_ENCRYPTION_KEY=change-me-openssl-rand-hex-16

# Public URL n8n uses for webhooks (set to your host/proxy in production)
WEBHOOK_URL=http://localhost:5678/

# ── Document pipeline ──────────────────────────────────────────────────────────
# Host folder mounted into n8n at /data. Create incoming/ processing/ processed/ failed/ rejected/
# inside it. In the imported workflow's Config node, set docRoot=/data.
DOC_ROOT=./data

# ── Gateway models + devices ───────────────────────────────────────────────────
# Model directory NAMES under deployment/models/ (place your converted OpenVINO IRs there).
VLM_MODEL=qwen2.5-vl-7b
LLM_MODEL=qwen3-8b-ov
# Chip per stage. GPU is the container default (well-supported). For NPU triage, set CLIP_DEVICE=NPU
# AND add "- /dev/accel/accel0" to the gateway service in podman-compose.yml (needs the host NPU driver).
OCR_DEVICE=GPU
LLM_DEVICE=GPU
CLIP_DEVICE=GPU
