{
  "name": "n8n-nodes-openvino",
  "version": "0.1.0",
  "description": "n8n custom nodes for OpenVINO Model Server — agentic AI workflows for Intel AI PCs (CPU/GPU/NPU)",
  "keywords": [
    "n8n-community-node-package",
    "openvino",
    "ovms",
    "ai",
    "agent",
    "intel",
    "gpu",
    "npu",
    "local-ai"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Nand Kishore R"
  },
  "main": "dist/nodes/OpenVinoModelServer/OpenVinoModelServer.node.js",
  "scripts": {
    "build": "tsc && find nodes -name '*.svg' -exec cp --parents {} dist/ \\; && find nodes -name '*.proto' -exec cp --parents {} dist/ \\;",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:integration:stack": "bash tests/integration/run-stack.sh",
    "lint": "eslint nodes credentials",
    "lint:fix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OpenVinoModelServerApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/OpenVinoModelServer/OpenVinoModelServer.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.15",
    "n8n-core": "^1.122.16",
    "n8n-workflow": "^1.120.9"
  }
}
